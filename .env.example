# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

VITE_GA_MEASUREMENT_ID=""

VITE_EMAILJS_SERVICE_ID=""
VITE_EMAILJS_TEMPLATE_ID=""
VITE_EMAILJS_CHAT_TEMPLATE_ID=""
VITE_EMAILJS_PUBLIC_KEY=""

VITE_ALGOLIA_APP_ID=""
VITE_ALGOLIA_SEARCH_KEY=""
VITE_ALGOLIA_INDEX_NAME="listings"

# Algolia Full-Text Search (Backend)
ALGOLIA_APP_ID=""
ALGOLIA_API_KEY=""
ALGOLIA_INDEX_NAME="listings"

# Firebase Admin SDK (Node.js) - Required for server-side db access
FIREBASE_SERVICE_ACCOUNT_KEY=""

# Redis
REDIS_URL=""
REDIS_HOST="spotted-loaf-funny-63490.db.redis.io"
REDIS_PORT="14446"
REDIS_PASSWORD=""
REDIS_REGION_URLS="europe-west3:redis://...,us-central1:redis://..."

# Monitoring & Observability
# SENTRY_DSN=""
# VITE_SENTRY_DSN=""
# LOG_LEVEL="info" # error, warn, info, debug
# LOG_FORMAT="pretty" # json, pretty
# ENABLE_TRACING="false" # set to "true" to enable OpenTelemetry trace SDK during container startup
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"

# Deployment
# APP_REGION="europe-west3"
# APP_MODE="full" # options: api, worker, full

# Stripe Checkout / Wallet Deposit
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Cloudflare Turnstile Spam Protection
# TURNSTILE_SECRET_KEY=""

# Professional Email / SMTP Configuration
SMTP_HOST="mail.myserver.com"
SMTP_PORT="587"
SMTP_USER="noreply@svetgradjevine.rs"
SMTP_PASS="password"

# BigQuery Analytics Export
# BIGQUERY_PROJECT_ID=""
# BIGQUERY_DATASET_ID="telemetry_analytics"

# Google Indexing API service account path
# GOOGLE_INDEXING_CREDENTIALS_PATH="/applet/google-indexing-sa.json"

# Service account email for Cloud Tasks
SERVICE_ACCOUNT_EMAIL=""

# Force Redis Failover to local memory cache (useful when Redis monthly quota/bandwidth is exceeded)
FORCE_REDIS_OFFLINE="false"

# Completely disable dashboard & global prewarm cycles to save Firestore read quota (highly recommended in sandbox/test environments)
DISABLE_PREWARM="true"


