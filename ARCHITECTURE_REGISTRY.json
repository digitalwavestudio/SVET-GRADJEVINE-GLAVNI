  "forbidden_code_grep_rules": [
    {
      "pattern": "setInterval\\s*\\(",
      "locations": [
        "./server/services/"
      ],
      "error_message": "Zabranjena je upotreba setInterval unutar novih runtime Express servisa. Koristi iskljucivo BullMQ i worker queue sisteme za asinkrone zadatke.",
      "exemptions": [
        "chat-archiver.service.ts",
        "cleanup.service.ts",
        "dashboard-lru.ts",
        "dlq-monitoring.service.ts",
        "dlq.worker.ts",
        "housekeeping.service.ts",
        "metrics.service.ts",
        "monitoring.service.ts",
        "outbox.worker.ts",
        "reconciliation.service.ts",
        "sse.service.ts",
        "viewStatsService.ts",
        "dashboard-prewarm.service.ts",
        "storage-cleanup.worker.ts"
      ]
    },
    {
      "pattern": "import\\s+.*\\s+from\\s+['\"]worker_threads['\"]",
      "locations": [
        "./server/"
      ],
      "error_message": "Zabranjeno je rucno instanciranje node Workera i in-memory threadova preko 'worker_threads'. Koristi iskljucivo BullMQ integraciju.",
      "exemptions": []
    },
    {
      "pattern": "onSnapshot\\s*\\(",
      "locations": [
        "./src/pages/",
        "./src/components/"
      ],
      "error_message": "Zabranjeni su nekontrolisani realtime onSnapshot listeneri na klijentu. Koristi TanStack Query polling sa visibility-state proveri-zasicenost zastitom ili preusmeri na Redis sync.",
      "exemptions": [
        "ChatWindow.tsx",
        "useChatWindow.tsx",
        "Chat.tsx"
      ]
    },
    {
      "pattern": "TODO:\\s*implementirati\\s*ostatak",
      "locations": [
        "./server/",
        "./src/"
      ],
      "error_message": "🚫 AI SLOP BYPASS: Strogo je zabranjeno ostavljanje 'TODO: implementirati ostatak' komentara umesto pisanja korisnog koda. Popuni logiku odmah.",
      "exemptions": []
    },
    {
      "pattern": "\\.\\.\\.\\s*ostatak\\s*koda",
      "locations": [
        "./server/",
        "./src/"
      ],
      "error_message": "🚫 AI SLOP TRUNCATION: Strogo je zabranjeno ostavljanje '... ostatak koda' umesto punog koda.",
