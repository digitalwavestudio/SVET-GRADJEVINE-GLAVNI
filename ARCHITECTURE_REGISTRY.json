  "technological_ceiling": {
    "background_jobs": {
      "approved": [
        "BullMQ"
      ],
      "forbidden": [
        "setInterval",
        "setTimeout polling loops",
        "in-memory-queue",
        "cron-node"
      ]
    },
    "caching": {
      "approved": [
        "Redis",
        "TanStack Query on client-side with explicit staleTime"
      ],
      "forbidden": [
        "in-memory plain global variables",
        "localstorage bypass for server state"
      ]
    },
    "search": {
      "approved": [
        "UnifiedSearchService",
        "Algolia Search Layer"
      ],
      "forbidden": [
        "raw Firestore collection-wide search with regex/contains",
        "custom memory searches"
      ]
    },
    "validation": {
      "approved": [
        "Zod Schema validation on BFF"
      ],
      "forbidden": [
        "pure manual standard js if-checks for body validation",
        "express-validator"
      ]
    },
    "database_writes": {
      "approved": [
        "Express API endpoints with Transactions & Outbox Pattern (UnifiedAdsService)"
      ],
      "forbidden": [
        "direct client-side Firestore raw writes for critical collections"
      ]
    },
    "metrics_accumulation": {
      "approved": [
        "ViewStatsService",
        "MetricsService using Redis hincrby and cron flushing to db.batch"
      ],
      "forbidden": [
        "live direct Firestore updates per individual click/view",
        "runtime Firestore count() queries on raw collections"
      ]
    }
  },
