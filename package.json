  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "simulate:prod": "tsx scripts/production_simulation.ts",
    "freeze-architecture": "tsx scripts/freeze_architecture.ts",
    "integrity-check": "tsx scripts/integrity_shield.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "npm audit --audit-level=high",
    "test:mutation": "stryker run",
    "test:contract": "vitest run server/tests/contract.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:rules": "vitest run server/tests/firestore-security.test.ts",
    "test:e2e": "playwright test"
  },
