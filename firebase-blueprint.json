    "Rfq": {
      "title": "B2B Request For Quotation (RFQ)",
      "description": "Tender specification sent to B2B suppliers",
      "type": "object",
      "properties": {
        "regionId": { "type": "string", "description": "ID of location/region" },
        "phone": { "type": "string" },
        "category": { "type": "string", "description": "Calculator category" },
        "specification": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["active", "processed", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["regionId", "phone", "category", "specification", "status", "createdAt"]
    }
  },
  "firestore": {
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Ledger of sensitive administrative actions (Backend write only)"
    },
    "/rfqs/{rfqId}": {
      "schema": "Rfq",
      "description": "Request for quotations submitted via calculators"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of platform administrators"
    },
    "/_migrations/{migrationId}": {
      "schema": "Migration",
      "description": "Migration tracking data"
    },
    "/_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Centralized system logs"
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Chat metadata"
    },
    "/conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Real-time messages"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Registered user accounts"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "All job postings"
    },
    "/machines/{machineId}": {
      "schema": "Machine",
      "description": "All construction equipment"
    },
    "/plots/{id}": {
      "schema": "RealEstate",
      "description": "Industrial lands and zones"
    },
    "/caterings/{id}": {
      "schema": "Catering",
      "description": "Food services for sites"
    },
    "/marketplace/{id}": {
      "schema": "Marketplace",
      "description": "B2B and P2P marketplace items"
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "All company profiles"
    },
    "/accommodations/{accommodationId}": {
      "schema": "Accommodation",
      "description": "All accommodation advertisements"
    },
    "/applications/{appId}": {
      "schema": "Application",
      "description": "All worker applications for jobs"
    },
    "/favorites/{id}": {
      "schema": "Favorite",
      "description": "User's saved advertisements"
    },
    "/checkouts/{id}": {
      "schema": "Checkout",
      "description": "All payment and checkout records"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Ledger of all wallet transactions (Backend write only)"
    },
    "/supportTickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "All support tickets submitted by users"
    },
    "/sites/{siteId}": {
      "schema": "Site",
      "description": "Construction sites"
    },
    "/sites/{siteId}/workers/{workerId}": {
      "schema": "Worker",
      "description": "Workers present on site"
    },
    "/sites/{siteId}/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Resources/machinery used on site"
